rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only the profiles collection is used by this app
    match /profiles/{profileId} {

      // Anyone can read profiles (needed for leaderboard + onSnapshot)
      allow read: if true;

      // Allow create/update only if document has valid structure
      allow create, update: if isValidProfile(request.resource.data);

      // Allow delete (needed for profile rename = delete old + create new)
      allow delete: if true;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['name', 'avatar', 'points'])
          && data.name is string
          && data.name.size() > 0
          && data.name.size() <= 50
          && data.avatar is string
          && data.points is number
          && data.points >= 0
          && data.points <= 100000;
    }
  }
}
